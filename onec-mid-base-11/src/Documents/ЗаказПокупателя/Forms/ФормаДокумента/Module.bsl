
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	//++ Лавриненко____29.03.2026: Добавление реквизитов "Контактное лицо, Согласованная скидка" и команды "Перерсчитать"
	Элемент = Элементы.Добавить("Дораб_КонтактноеЛицо",Тип("ПолеФормы"),Элементы.ГруппаШапкаПраво);
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект.Дораб_КонтактноеЛицо"; 
	
	ГруппаСкидка = ЭтотОбъект.Элементы.Добавить("ГруппаСкидка", Тип("ГруппаФормы"),Элементы.ГруппаШапкаЛево);
	ГруппаСкидка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаСкидка.ОтображатьЗаголовок = ЛОЖЬ;  
	ГруппаСкидка.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
	Элемент = Элементы.Добавить("Дораб_СогласованнаяСкидка",Тип("ПолеФормы"),Элементы.ГруппаСкидка);
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект.Дораб_СогласованнаяСкидка"; 
	Элемент.УстановитьДействие("ПриИзменении","Дораб_СогласованнаяСкидкаПриИзменении");
	
	Команда = Команды.Добавить("Дораб_ПересчитатьТаблицу");  
	Команда.Заголовок = "Пересчитать таблицу";
	Команда.Действие = "Дораб_ПересчитатьТаблицу";  
	
	КнопкаФормы = Элементы.Добавить("КнопкаПересчитатьТаблицу", Тип("КнопкаФормы"),Элементы.ГруппаСкидка);
	КнопкаФормы.ИмяКоманды = "Дораб_ПересчитатьТаблицу";
	КнопкаФормы.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	
	//-- Лавриненко____29.03.2026  	
	
КонецПроцедуры

