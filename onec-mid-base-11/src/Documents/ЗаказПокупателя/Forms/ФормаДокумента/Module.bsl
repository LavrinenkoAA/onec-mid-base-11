#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	//++ Лавриненко____29.03.2026: Изменение расчета сумма учитывая скидку
	//КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	//ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	КоэффициентСкидки = 1 - (ТекущиеДанные.Скидка + Объект.Дораб_СогласованнаяСкидка) / 100;
	Если КоэффициентСкидки > 0 Тогда 
		ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	Иначе
		ТекущиеДанные.Сумма = 0;
	КонецЕсли;
	//-- Лавриненко____29.03.2026
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

&НаКлиенте
Процедура Дораб_ПересчитатьТаблицы()
	
	//++ Лавриненко____29.03.2026: Перерасчет всех строк таблиц
	ТабОбх = Объект.Товары;
	Для Каждого стрТабл из ТабОбх Цикл 
		РассчитатьСуммуСтроки(стрТабл);
   	КонецЦикла;	
	
	ТабОбх = Объект.Услуги;
	Для Каждого стрТабл из ТабОбх Цикл 
		РассчитатьСуммуСтроки(стрТабл);
	КонецЦикла;	   
	//-- Лавриненко____29.03.2026

КонецПроцедуры

&НаКлиенте
Процедура Дораб_ПересчитатьТаблицу(Команда)
	
	//++ Лавриненко____29.03.2026: Добавление команды перерасчета таблицы
	Дораб_ПересчитатьТаблицы();
	//-- Лавриненко____29.03.2026
КонецПроцедуры 

&НаКлиенте
Асинх Процедура Дораб_СогласованнаяСкидкаПриИзменении(Элемент)
	
	Если Объект.Товары.Количество() > 0 ИЛИ Объект.Услуги.Количество() > 0 Тогда
		Вопрос = ВопросАсинх("Изменен процент скидки. Пересчитать таблицу товаров и услуг?", РежимДиалогаВопрос.ДаНет);
   		ОтветНаВопрос = Ждать Вопрос;
		Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
			Дораб_ПересчитатьТаблицы(); 
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


